{
  "name": "groovework-desktop",
  "version": "1.0.4",
  "private": true,
  "description": "Groove Work — десктоп-клиент (тонкая обёртка над веб-версией)",
  "author": "Groove Work",
  "desktopName": "groovework",
  "main": "main.js",
  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ru.kodass.groovework",
    "productName": "GrooveWork",
    "artifactName": "GrooveWork-${version}-${os}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "build/**"
    ],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
