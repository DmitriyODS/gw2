{
  "name": "groovework-desktop",
  "version": "1.0.9",
  "private": true,
  "description": "Groove Work — десктоп-клиент (тонкая обёртка над веб-версией)",
  "author": "Groove Work",
  "desktopName": "groovework",
  "main": "main.js",
  "devDependencies": {
    "electron": "38.0.0",
    "electron-builder": "26.0.12"
  },
  "build": {
    "appId": "ru.kodass.groovework",
    "productName": "GrooveWork",
    "artifactName": "GrooveWork-${version}-${os}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "build/**"
    ],
    "mac": {
      "target": {
        "target": "dmg",
        "arch": "arm64"
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GrooveWork",
      "guid": "ru.kodass.groovework",
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ]
    }
  }
}