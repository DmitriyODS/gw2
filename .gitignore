# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Env
.env
*.env.local
.env.deploy

# Uploads (dev-файлы пользователей: аватарки, вложения)
uploads/

# APK мобильного приложения (бинарь, заливается на сервер через make deploy-apk;
# apps/version.json с номером сборки остаётся в git — его читает Gradle)
apps/*.apk

# Артефакты десктоп-клиента (заливаются через make deploy-desktop;
# apps/desktop/version.json остаётся в git — версия обёртки)
apps/desktop/*.dmg
apps/desktop/*.exe
apps/desktop/*.AppImage

# Node
front/node_modules/
front/dist/

# IDE
.vscode/
.idea/
.claude/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Backup data (содержит реальные данные пользователей, не коммитим)
backup.json
backups/

# Logs
*.log
./apps/groovework.apk

# Случайно собранные Go-бинарники сервисов (go build без -o в каталоге сервиса)
back-go/*/*svc
