# Теги образов из Docker Hub (osipovskijdima/groove_work). По умолчанию —
# плавающие migrate/gateway/calls/auth/messenger/ai/pets/tasks/push/registry/
# calendar/diary/portal/mail/front (их двигает каждый `make push`). Для
# отката раскомментировать и указать версионный тег, затем повторить деплой:
#MIGRATE_TAG=migrate-3.7.0
#GATEWAY_TAG=gateway-3.7.0
#CALLS_TAG=calls-3.7.0
#AUTH_TAG=auth-3.7.0
#MESSENGER_TAG=messenger-3.7.0
#AI_TAG=ai-3.7.0
#PETS_TAG=pets-3.7.0
#TASKS_TAG=tasks-3.7.0
#PUSH_TAG=push-3.7.0
#REGISTRY_TAG=registry-3.7.0
#CALENDAR_TAG=calendar-3.7.0
#DIARY_TAG=diary-3.7.0
#PORTAL_TAG=portal-3.7.0
#MAIL_TAG=mail-3.7.0
#FRONT_TAG=front-3.7.0

# Пуш-уведомления (FCM, Android). Содержимое service-account JSON ключа
# Firebase (одной строкой). Firebase Console → Project settings →
# Service accounts → Generate new private key. Без него pushsvc работает,
# но пуши не отправляются. Пример:
#FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

# База данных PostgreSQL
DB_NAME=grovework
DB_USER=grovework
DB_PASSWORD=CHANGE_ME_strong_password_here

# PASETO-токены платформы (выпускает Go-микросервис авторизации back-go/auth).
# PASETO_PRIVATE_KEY — Ed25519 seed||public, 64 байта hex: подписывает
#   access-токены (v4.public), знает ТОЛЬКО authsvc.
# PASETO_PUBLIC_KEY  — публичная половина той же пары, 32 байта hex:
#   по ней остальные сервисы проверяют подпись. Должна соответствовать
#   приватному ключу — deploy_server.sh генерирует пару сам.
# PASETO_REFRESH_KEY — симметричный ключ refresh-токенов (v4.local),
#   32 байта hex, тоже только authsvc.
# Сгенерировать вручную (или доверить deploy_server.sh):
#   python3 - <<'EOF'
#   from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
#   from cryptography.hazmat.primitives import serialization as s
#   import secrets
#   k = Ed25519PrivateKey.generate()
#   seed = k.private_bytes(s.Encoding.Raw, s.PrivateFormat.Raw, s.NoEncryption()).hex()
#   pub = k.public_key().public_bytes(s.Encoding.Raw, s.PublicFormat.Raw).hex()
#   print(f"PASETO_PRIVATE_KEY={seed}{pub}\nPASETO_PUBLIC_KEY={pub}\nPASETO_REFRESH_KEY={secrets.token_hex(32)}")
#   EOF
PASETO_PRIVATE_KEY=
PASETO_PUBLIC_KEY=
PASETO_REFRESH_KEY=

# LiveKit — медиа-сервер звонков (SFU): аудио/видео-конференции до 8 человек,
# чат звонка, гостевые ссылки. Поднимается сервисом livekit в docker-compose;
# access-токены этим же ключом подписывает Go-микросервис звонков (сервис
# calls, back-go/calls) — он же принимает вебхуки LiveKit.
#
# LIVEKIT_API_KEY    — произвольный идентификатор ключа (например, gw2prod)
# LIVEKIT_API_SECRET — случайная строка ≥32 символов:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# LIVEKIT_CLIENT_URL — как браузеры достукиваются до LiveKit. По умолчанию
#   «/livekit» (через nginx того же домена, wss). Менять не нужно.
# LIVEKIT_TURN_DOMAIN — домен встроенного в LiveKit TURN-relay (пробивает
#   NAT/VPN/мобильные сети, где прямой UDP закрыт). Должен совпадать с
#   доменом сертификата Let's Encrypt (тот же том, что у nginx). По умолчанию
#   gw.kodass.ru — менять только при смене основного домена.
#
# На сервере открыть в firewall (deploy_server.sh делает это сам при ufw):
#   медиа  — 7881/TCP, 7882/UDP
#   TURN   — 5349/TCP (TLS), 3478/UDP
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
#LIVEKIT_CLIENT_URL=/livekit
#LIVEKIT_TURN_DOMAIN=gw.kodass.ru

# AI / ProxyAPI — шифрование API-ключей компаний (нужен только
# Go-микросервису ai, back-go/ai). Каждый суперадминистратор компании сам
# вводит свой ключ от ProxyAPI в настройках. Ключи хранятся в БД в
# зашифрованном виде Fernet'ом; ключ шифрования — здесь, в env. Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВНИМАНИЕ: при ротации этого ключа все сохранённые ключи компаний станут
# нерасшифровываемыми и AI-фичи у всех выключатся, пока ключи не введут
# заново. Не теряем и не меняем без необходимости.
AI_KEY_ENCRYPTION_KEY=

# ИИ техподдержки (dev-чат мессенджера): ПЛАТФОРМЕННЫЙ ключ LLM (ProxyAPI/
# OpenAI), не компанийный. Пустой — ИИ поддержки выключен, бот отвечает
# прежним канированным автоответом. Модель опциональна (по умолчанию
# gpt-4o-mini).
SUPPORT_AI_API_KEY=
SUPPORT_AI_MODEL=

# YouGile-интеграция — шифрование персональных API-ключей пользователей.
# Каждый пользователь подключает свой YouGile-аккаунт в настройках, мы храним
# полученный API-ключ в БД зашифрованным; ключ шифрования — здесь, в env.
# Формат Fernet, тот же генератор:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# При смене этого ключа все привязки YouGile нужно будет переподключить
# (расшифровка вернёт None — UI попросит пользователя ввести логин/пароль).
YOUGILE_ENC_KEY=

# YouGile-интеграция — публичный URL приложения для webhook'а.
# При включении интеграции в настройках компании мы регистрируем в YouGile
# webhook вида POST {base}/api/yougile/webhook/<companyId>/<secret> и YG
# присылает события task-*. Без этого env webhook не зарегистрируется,
# но импорт/экспорт карточек продолжат работать (это «вторая половина»
# интеграции — двусторонняя живая синхра).
#
# Должен быть прокидываем извне через nginx (TLS обязательно): nginx уже
# проксирует /api/yougile в tasksvc — location уже есть.
# Пример: https://gw.example.com
YOUGILE_WEBHOOK_PUBLIC_BASE=

# ── Рассылка писем (mailsvc) ──────────────────────────────────────
# Параметры SMTP для писем подтверждения email при регистрации. HOST/PORT/FROM
# обязательны в проде; USER/PASSWORD — для серверов с авторизацией.
# SMTP_TLS: starttls (587) | tls (implicit, 465) | none.
# Примеры:
#   Яндекс:   SMTP_HOST=smtp.yandex.ru   SMTP_PORT=465  SMTP_TLS=tls
#   Mail.ru:  SMTP_HOST=smtp.mail.ru     SMTP_PORT=465  SMTP_TLS=tls
#   Gmail:    SMTP_HOST=smtp.gmail.com   SMTP_PORT=587  SMTP_TLS=starttls
#   SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Groove Work
SMTP_TLS=starttls

# Публичный базовый URL приложения — для ссылок подтверждения email в письмах
# (https://gw.example.com → .../verify-email?token=...).
APP_PUBLIC_BASE_URL=

# ── Файловое хранилище (pkg/storage) ──────────────────────────────
# Где лежит пользовательский контент (вложения, картинки/файлы реестров и
# календарей, аватарки). local — общий uploads-том (dev). s3 — объектное
# хранилище Beget (prod): создать бакет в панели, выставить ему анонимный
# s3:GetObject (read-only) и подставить имя бакета в nginx.prod.conf
# (location /uploads/ → .../<bucket>/). См. DEPLOY.md.
STORAGE_BACKEND=s3
S3_ENDPOINT=s3.ru1.storage.beget.cloud
S3_REGION=ru1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Навык Алисы и Яндекс ID ───────────────────────────────────────
# OAuth-провайдер связки аккаунтов навыка Алисы: deploy_server.sh генерирует
# креды сам — скопируйте их в консоль Яндекс.Диалогов (client_id/client_secret
# навыка). Пусто — эндпоинты /api/auth/oauth/* выключены.
OAUTH_ALICE_CLIENT_ID=
OAUTH_ALICE_CLIENT_SECRET=
# Вход/регистрация через Яндекс ID: креды приложения с oauth.yandex.ru
# (redirect URI приложения — https://<домен>/yandex-callback). Пусто —
# кнопка «Войти с Яндексом» скрыта.
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
