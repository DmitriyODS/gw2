# База данных PostgreSQL
DB_NAME=grovework
DB_USER=grovework
DB_PASSWORD=CHANGE_ME_strong_password_here

# Flask секреты — сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_random_jwt_secret_min_32_chars
SECRET_KEY=CHANGE_ME_random_flask_secret_min_32_chars

# LiveKit — медиа-сервер звонков (SFU): аудио/видео-конференции до 8 человек,
# чат звонка, гостевые ссылки. Поднимается сервисом livekit в docker-compose;
# access-токены этим же ключом подписывает Go-микросервис звонков (сервис
# calls, back-go/calls) — он же принимает вебхуки LiveKit.
#
# LIVEKIT_API_KEY    — произвольный идентификатор ключа (например, gw2prod)
# LIVEKIT_API_SECRET — случайная строка ≥32 символов:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# LIVEKIT_CLIENT_URL — как браузеры достукиваются до LiveKit. По умолчанию
#   «/livekit» (через nginx того же домена, wss). Менять не нужно.
#
# На сервере открыть в firewall медиа-порты: 7881/TCP и 7882/UDP:
#   ufw allow 7881/tcp && ufw allow 7882/udp
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
#LIVEKIT_CLIENT_URL=/livekit

# AI / ProxyAPI — шифрование API-ключей компаний.
# Каждый суперадминистратор компании сам вводит свой ключ от ProxyAPI в
# настройках. Ключи хранятся в БД в зашифрованном виде Fernet'ом; ключ
# шифрования — здесь, в env. Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВНИМАНИЕ: при ротации этого ключа все сохранённые ключи компаний станут
# нерасшифровываемыми и AI-фичи у всех выключатся, пока ключи не введут
# заново. Не теряем и не меняем без необходимости.
AI_KEY_ENCRYPTION_KEY=

# YouGile-интеграция — шифрование персональных API-ключей пользователей.
# Каждый пользователь подключает свой YouGile-аккаунт в настройках, мы храним
# полученный API-ключ в БД зашифрованным; ключ шифрования — здесь, в env.
# Формат Fernet, тот же генератор:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# При смене этого ключа все привязки YouGile нужно будет переподключить
# (расшифровка вернёт None — UI попросит пользователя ввести логин/пароль).
YOUGILE_ENC_KEY=

# YouGile-интеграция — публичный URL приложения для webhook'а.
# При включении интеграции в настройках компании мы регистрируем в YouGile
# webhook вида POST {base}/api/yougile/webhook/<companyId>/<secret> и YG
# присылает события task-*. Без этого env webhook не зарегистрируется,
# но импорт/экспорт карточек продолжат работать (это «вторая половина»
# интеграции — двусторонняя живая синхра).
#
# Должен быть прокидываем извне через nginx (TLS обязательно): nginx уже
# проксирует /api/* в Flask, отдельного location'а добавлять не нужно.
# Пример: https://gw.example.com
YOUGILE_WEBHOOK_PUBLIC_BASE=
