# База данных PostgreSQL
DB_NAME=grovework
DB_USER=grovework
DB_PASSWORD=CHANGE_ME_strong_password_here

# Flask секреты — сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_random_jwt_secret_min_32_chars
SECRET_KEY=CHANGE_ME_random_flask_secret_min_32_chars

# WebRTC TURN-сервер (coturn). ОБЯЗАТЕЛЕН для звонков между разными сетями
# (мобильный интернет, домашний NAT) — без него ICE застревает на «checking»
# и медиа не идёт, хотя звонок «соединяется». На проде coturn поднимается
# автоматически (сервис coturn в docker-compose.prod.yml, профиль не нужен).
#
# TURN_HOST   — ПУБЛИЧНЫЙ IP сервера (именно IP-адрес, не домен!). Клиент идёт
#               на turn:<IP>:3478 напрямую, и coturn анонсирует этот же IP.
# TURN_SECRET — случайная строка: python3 -c "import secrets; print(secrets.token_hex(32))"
#
# На сервере открыть в firewall: 3478/UDP, 3478/TCP и UDP 49152-49200, напр.:
#   ufw allow 3478/udp && ufw allow 3478/tcp && ufw allow 49152:49200/udp
TURN_HOST=
TURN_PORT=3478
TURN_REALM=grovework
TURN_SECRET=
