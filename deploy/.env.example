# Теги образов из Docker Hub (osipovskijdima/groove_work). По умолчанию —
# плавающие migrate/gateway/calls/auth/messenger/ai/groove/tasks/front
# (их двигает каждый `make push`). Для отката раскомментировать и указать
# версионный тег, затем повторить деплой:
#MIGRATE_TAG=migrate-3.7.0
#GATEWAY_TAG=gateway-3.7.0
#CALLS_TAG=calls-3.7.0
#AUTH_TAG=auth-3.7.0
#MESSENGER_TAG=messenger-3.7.0
#AI_TAG=ai-3.7.0
#GROOVE_TAG=groove-3.7.0
#TASKS_TAG=tasks-3.7.0
#FRONT_TAG=front-3.7.0

# База данных PostgreSQL
DB_NAME=grovework
DB_USER=grovework
DB_PASSWORD=CHANGE_ME_strong_password_here

# PASETO-токены платформы (выпускает Go-микросервис авторизации back-go/auth).
# PASETO_PRIVATE_KEY — Ed25519 seed||public, 64 байта hex: подписывает
#   access-токены (v4.public), знает ТОЛЬКО authsvc.
# PASETO_PUBLIC_KEY  — публичная половина той же пары, 32 байта hex:
#   по ней остальные сервисы проверяют подпись. Должна соответствовать
#   приватному ключу — deploy_server.sh генерирует пару сам.
# PASETO_REFRESH_KEY — симметричный ключ refresh-токенов (v4.local),
#   32 байта hex, тоже только authsvc.
# Сгенерировать вручную (или доверить deploy_server.sh):
#   python3 - <<'EOF'
#   from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
#   from cryptography.hazmat.primitives import serialization as s
#   import secrets
#   k = Ed25519PrivateKey.generate()
#   seed = k.private_bytes(s.Encoding.Raw, s.PrivateFormat.Raw, s.NoEncryption()).hex()
#   pub = k.public_key().public_bytes(s.Encoding.Raw, s.PublicFormat.Raw).hex()
#   print(f"PASETO_PRIVATE_KEY={seed}{pub}\nPASETO_PUBLIC_KEY={pub}\nPASETO_REFRESH_KEY={secrets.token_hex(32)}")
#   EOF
PASETO_PRIVATE_KEY=
PASETO_PUBLIC_KEY=
PASETO_REFRESH_KEY=

# LiveKit — медиа-сервер звонков (SFU): аудио/видео-конференции до 8 человек,
# чат звонка, гостевые ссылки. Поднимается сервисом livekit в docker-compose;
# access-токены этим же ключом подписывает Go-микросервис звонков (сервис
# calls, back-go/calls) — он же принимает вебхуки LiveKit.
#
# LIVEKIT_API_KEY    — произвольный идентификатор ключа (например, gw2prod)
# LIVEKIT_API_SECRET — случайная строка ≥32 символов:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# LIVEKIT_CLIENT_URL — как браузеры достукиваются до LiveKit. По умолчанию
#   «/livekit» (через nginx того же домена, wss). Менять не нужно.
#
# На сервере открыть в firewall медиа-порты: 7881/TCP и 7882/UDP:
#   ufw allow 7881/tcp && ufw allow 7882/udp
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
#LIVEKIT_CLIENT_URL=/livekit

# AI / ProxyAPI — шифрование API-ключей компаний (нужен только
# Go-микросервису ai, back-go/ai). Каждый суперадминистратор компании сам
# вводит свой ключ от ProxyAPI в настройках. Ключи хранятся в БД в
# зашифрованном виде Fernet'ом; ключ шифрования — здесь, в env. Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВНИМАНИЕ: при ротации этого ключа все сохранённые ключи компаний станут
# нерасшифровываемыми и AI-фичи у всех выключатся, пока ключи не введут
# заново. Не теряем и не меняем без необходимости.
AI_KEY_ENCRYPTION_KEY=

# YouGile-интеграция — шифрование персональных API-ключей пользователей.
# Каждый пользователь подключает свой YouGile-аккаунт в настройках, мы храним
# полученный API-ключ в БД зашифрованным; ключ шифрования — здесь, в env.
# Формат Fernet, тот же генератор:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# При смене этого ключа все привязки YouGile нужно будет переподключить
# (расшифровка вернёт None — UI попросит пользователя ввести логин/пароль).
YOUGILE_ENC_KEY=

# YouGile-интеграция — публичный URL приложения для webhook'а.
# При включении интеграции в настройках компании мы регистрируем в YouGile
# webhook вида POST {base}/api/yougile/webhook/<companyId>/<secret> и YG
# присылает события task-*. Без этого env webhook не зарегистрируется,
# но импорт/экспорт карточек продолжат работать (это «вторая половина»
# интеграции — двусторонняя живая синхра).
#
# Должен быть прокидываем извне через nginx (TLS обязательно): nginx уже
# проксирует /api/yougile в tasksvc — location уже есть.
# Пример: https://gw.example.com
YOUGILE_WEBHOOK_PUBLIC_BASE=
