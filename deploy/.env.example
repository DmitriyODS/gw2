# База данных PostgreSQL
DB_NAME=grovework
DB_USER=grovework
DB_PASSWORD=CHANGE_ME_strong_password_here

# Flask секреты — сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_random_jwt_secret_min_32_chars
SECRET_KEY=CHANGE_ME_random_flask_secret_min_32_chars

# WebRTC TURN-сервер. Нужен, чтобы звонки пробивались через NAT (домашний
# интернет, мобильная сеть). Если не задано — клиенты используют только STUN
# и часть звонков может не подключиться.
# Запуск coturn: docker compose --profile calls up -d
# На сервере открыть в firewall: 3478/UDP, 3478/TCP и UDP 49152-49200.
TURN_HOST=
TURN_PORT=3478
TURN_REALM=grovework
TURN_SECRET=
