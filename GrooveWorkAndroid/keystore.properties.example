# Подпись релизного APK. Скопируй в keystore.properties и заполни:
#   cp keystore.properties.example keystore.properties
# Файл keystore.properties и сам .jks — в .gitignore (это секреты, НЕ коммитим).
#
# Ключ создаётся один раз и хранится бессрочно: обновление установленного
# приложения примет только APK, подписанный ТЕМ ЖЕ ключом. Потеря ключа =
# обновлять существующие установки нельзя (только переустановка вручную).

# Путь к хранилищу относительно каталога GrooveWorkAndroid/
storeFile=groovework-release.jks
storePassword=ЗАМЕНИ_МЕНЯ
keyAlias=groovework
keyPassword=ЗАМЕНИ_МЕНЯ
