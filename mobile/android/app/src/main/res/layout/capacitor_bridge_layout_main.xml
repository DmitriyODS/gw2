<?xml version="1.0" encoding="utf-8"?>
<!-- Перекрывает одноимённый layout Capacitor: ставит наш GrooveWebView на тот
     же @id/webview, по которому Bridge находит WebView (Bridge.java:
     findViewById(R.id.webview)). Нужен, чтобы включить приём картинок с
     клавиатуры (см. GrooveWebView). При апгрейде @capacitor/android — сверить
     с библиотечным capacitor_bridge_layout_main.xml. -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.getcapacitor.BridgeActivity">

    <com.kodass.groovework.GrooveWebView
        android:id="@+id/webview"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
